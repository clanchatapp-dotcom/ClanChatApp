# ============================================================================
# ClanChat Environment Configuration
# ============================================================================

# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=clanchat

# JWT
JWT_SECRET=your-secure-secret-here-min-32-characters-long

# DM Encryption (AES-256)
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DM_ENCRYPTION_KEY=

# S3 Storage (Local Minio or AWS)
# For local development with Minio: http://localhost:9000
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=clanchat

# OAuth (Optional - Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App Configuration
APP_NAME=ClanChat
REACT_APP_BACKEND_URL=http://localhost:8000
REACT_APP_FRONTEND_URL=http://localhost:3000

# Optional: CEOP/NCMEC Reporting
# CEOP_ENDPOINT=https://report.cybertip.org/api/v1/report
